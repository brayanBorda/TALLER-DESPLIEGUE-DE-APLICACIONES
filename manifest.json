{
  "id": "./index.html",
  "name": "Chat para Superhéroes",
  "short_name": "PWA Chat",
  "description": "Chat demo tipo timeline para practicar despliegue de aplicaciones PWA.",
  "version": "1.0.0",
  "lang": "es-CO",
  "dir": "ltr",
  "background_color": "#d0d3d4",
  "theme_color": "#3498db",

  "icons": [
    {
      "src": "img/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png"
    },
    {
      "src": "img/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png"
    },
    {
      "src": "img/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png"
    },
    {
      "src": "img/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png"
    },
    {
      "src": "img/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png"
    },
    {
      "src": "img/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "img/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "scope": "./",
  "permissions": ["notifications", "geolocation", "camera"],
  "capture_links": "existing-client-navigate",

  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/plain": [".txt"],
        "image/png": [".png"]
      }
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+chat",
      "url": "./index.html?action=%s"
    }
  ],

  "start_url": "./index.html",
  "display": "standalone",
  "orientation": "portrait",

  "screenshots": [
    {
      "src": "img/screenshot-mobile.png",
      "sizes": "430x932",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Vista móvil de Chat para héroes"
    },
    {
      "src": "img/screenshot-desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Vista escritorio de Chat para héroes"
    }
  ],

  "related_applications": [],
  "prefer_related_applications": false,

  "categories": ["education", "social", "utilities"],

  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",

  "launch_handler": {
    "client_mode": "navigate-existing"
  },

  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "shortcuts": [
    {
      "name": "Abrir chat",
      "short_name": "Chat",
      "description": "Ir a la pantalla principal del chat.",
      "url": "./index.html",
      "icons": [
        {
          "src": "img/icons/icon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ]
}
